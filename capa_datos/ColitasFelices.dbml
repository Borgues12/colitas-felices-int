      <Association Name="FK_rel_revisor" Member="Rel_perfil_documento" ThisKey="CuentaID" OtherKey="RevisadoPor" Type="Rel_perfil_documento" DeleteRule="NO ACTION" />
      <Association Name="FK_sesion_cuenta" Member="Cuenta_token_sesion" ThisKey="CuentaID" OtherKey="CuentaID" Type="Cuenta_token_sesion" DeleteRule="NO ACTION" />
    </Type>
