  <Table Name="dbo.cuenta" Member="Cuenta">
    <Type Name="Cuenta">
      <Column Name="CuentaID" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
